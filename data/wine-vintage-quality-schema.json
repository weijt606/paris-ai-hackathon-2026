  "dynamicAdjustments": [
    {
      "id": "market_sentiment_cap",
      "appliesTo": "market_expectation_sentiment",
      "formula": "if sentiment_score >= 80 then +min(6, (sentiment_score - 80) / 20 * 6); if sentiment_score <= 35 then -min(10, (35 - sentiment_score) / 35 * 10); else 0",
      "purpose": "Allow expectations to move the score, but prevent hype from rescuing a climatically poor vintage."
    },
    {
      "id": "compound_heat_drought_penalty",
      "appliesTo": [
        "extreme_max_temperature",
        "dryness_index",
        "heat_days"
      ],
      "formula": "if extreme_max_temperature_score < 45 and dryness_index_score < 45 then -12; else if heat_days_score < 50 and dryness_index_score < 60 then -6; else 0",
      "purpose": "Capture interaction effects where heat and drought together are worse than either feature alone."
    },
    {
      "id": "rain_disease_penalty",
      "appliesTo": [
        "harvest_rain",
        "flood_excess_rain",
        "disease_pressure"
      ],
      "formula": "if harvest_rain_score < 45 and disease_pressure_score < 60 then -10; else if flood_excess_rain_score < 50 then -6; else 0",
      "purpose": "Prevent high non-rain features from hiding rot, dilution, and splitting risk."
    },
    {
      "id": "policy_risk_penalty",
      "appliesTo": "policy_trade_risk",
      "formula": "if policy_trade_risk_score < 40 then -8; if policy_trade_risk_score < 20 then -15; else 0",
      "purpose": "Represent non-natural commercial drag from tariffs, regulation, or distribution disruption."
    },
    {
      "id": "policy_support_boost",
      "appliesTo": "policy_support_signal",
      "formula": "if policy_support_signal_score >= 70 then +min(5, (policy_support_signal_score - 70) / 30 * 5); else 0",
      "purpose": "Capture concrete policy tailwinds without allowing politics to overpower vineyard evidence."
    },
    {
      "id": "policy_adverse_penalty",
      "appliesTo": "policy_adverse_signal",
      "formula": "if policy_adverse_signal_score <= 60 then -min(10, (60 - policy_adverse_signal_score) / 60 * 10); else 0",
      "purpose": "Penalize tariffs, restrictions, disputes, or regulation that directly harms production, release, or demand."
    },
    {
      "id": "public_and_critic_expectation_adjustment",
      "appliesTo": [
        "public_expectation_momentum",
        "critic_pre_release_signal"
      ],
      "formula": "positive = min(10, max(0, public_expectation_points) + max(0, critic_pre_release_points)); negative = max(-9, min(0, public_expectation_points) + min(0, critic_pre_release_points)); return positive + negative",
      "purpose": "Let public and expert expectation move the market-facing score while keeping upside bounded."
    },
    {
      "id": "trade_liquidity_adjustment",
      "appliesTo": "trade_liquidity_demand",
      "formula": "if trade_liquidity_demand_score >= 70 then +min(5, (trade_liquidity_demand_score - 70) / 30 * 5); if trade_liquidity_demand_score <= 45 then -min(8, (45 - trade_liquidity_demand_score) / 45 * 8); else 0",
      "purpose": "Reflect asymmetric commercial risk: weak demand hurts more than strong demand helps."
    },
    {
      "id": "variety_fit_climate_interaction",
      "appliesTo": [
        "grape_variety_region_fit",
        "cultivar_climate_resilience",
        "gst",
        "extreme_max_temperature",
        "dryness_index"
      ],
      "formula": "if grape_variety_region_fit_score < 45 and (extreme_max_temperature_score < 55 or dryness_index_score < 50) then -8; else if cultivar_climate_resilience_score > 75 and gst_score > 55 then +min(4, (cultivar_climate_resilience_score - 75) / 25 * 4); else 0",
      "purpose": "Model variety-specific sensitivity so grape type, rootstock, and adaptation matter when weather becomes stressful."
    },
    {
      "id": "reputation_and_sustainability_adjustment",
      "appliesTo": [
        "chateau_reputation_momentum",
        "certification_sustainability_premium"
      ],
      "formula": "return clamp(chateau_reputation_points + certification_sustainability_points, -7, 8)",
      "purpose": "Apply bounded market trust effects from producer reputation, certification, and sustainability credibility."
    },
    {
      "id": "logistics_supply_chain_penalty",
      "appliesTo": "logistics_supply_chain_risk",
      "formula": "if logistics_supply_chain_risk_score <= 65 then -min(7, (65 - logistics_supply_chain_risk_score) / 65 * 7); else 0",
      "purpose": "Account for release-year operational friction that affects availability and perceived vintage success."
    }
  ],
