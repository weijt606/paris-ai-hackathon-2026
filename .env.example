# =============================================================================
# Paris AI Hackathon 2026 — Environment Variables
# =============================================================================
# Copy this file to `.env.local` and fill in real values.
# `.env.local` is git-ignored. NEVER commit real keys.
#
# Every adapter is env-gated: leave a key blank and the corresponding
# sponsor route returns 503 instead of crashing. Demo mode (below) lets
# the UI work end-to-end with zero keys.
# =============================================================================

# ---- Public-safe ----
NEXT_PUBLIC_APP_NAME="Paris Hack 2026"
# When DEMO_MODE=true, all sponsor calls return fixtures from src/lib/demo/fixtures.ts
# Use this for offline rehearsal / saving credits.
NEXT_PUBLIC_DEMO_MODE=false

# ---- Sponsor: OpenAI ----
# https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Model id — bump to whatever GA is current on the day:
OPENAI_MODEL=gpt-4o-mini

# ---- Sponsor: Anthropic ----
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
# Use a GA model for the demo path, not preview/beta:
ANTHROPIC_MODEL=claude-sonnet-4-6

# ---- Sponsor: Fal (image/video generation) ----
# https://fal.ai/dashboard/keys
FAL_KEY=
# Default image model — override per-call when needed:
FAL_IMAGE_MODEL=fal-ai/flux/schnell

# ---- Sponsor: Gradium (voice / TTS / STT) ----
# Get a key from the Gradium dashboard provided at the event.
GRADIUM_API_KEY=
GRADIUM_BASE_URL=https://api.gradium.ai

# ---- Sponsor: Slng.ai (voice infrastructure) ----
# Get a key from the Slng dashboard provided at the event.
SLNG_API_KEY=
SLNG_BASE_URL=https://api.slng.ai

# ---- Integration: Tavily (public web search for tavily-agent) ----
# https://app.tavily.com/home
TAVILY_API_KEY=

# ---- Integration: Pioneer.ai (post-training / self-evolving feedback loop) ----
# Owner provides docs + key. Adapter stub lives at src/lib/training/pioneer.ts.
PIONEER_API_KEY=
PIONEER_BASE_URL=https://api.pioneer.ai

# ---- Database (optional — only if a feature persists data) ----
DATABASE_URL=file:./data/dev.db

# ---- Server runtime ----
# Used by some adapters for absolute-URL callbacks. Leave for localhost dev.
NEXT_PUBLIC_APP_URL=http://localhost:3000
