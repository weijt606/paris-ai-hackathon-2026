# =============================================================================
# Wine Intelligence — Environment Variables
# =============================================================================
# Copy this file to `.env.local` and fill in real values.
# `.env.local` is git-ignored. NEVER commit real keys.
#
# Every adapter is env-gated. Leave a key blank and the corresponding feature
# degrades to a stub or fixture. Demo mode (below) lets the UI work end-to-end
# with zero keys.
#
# Sponsors for this project: OpenAI, Tavily, Pioneer.ai
# =============================================================================

# ---- Public-safe ----
NEXT_PUBLIC_APP_NAME="Wine Signals"
# When DEMO_MODE=true, the orchestrator returns fixtures from
# src/lib/demo/fixtures.ts. Use for offline rehearsal / saving credits.
NEXT_PUBLIC_DEMO_MODE=false

# ---- OpenAI (orchestrator brain — Chat Completions tool-use loop) ----
# https://platform.openai.com/api-keys
OPENAI_API_KEY=
# RECOMMENDED: gpt-4o-mini — orchestrator/extraction tasks are structured-JSON
# emission against a schema; no reasoning needed. ~3-6s per call.
# AVOID reasoning models (gpt-5*, o-series): they do 20-40s of internal thinking
# AND reject custom temperature, AND don't speed up these tasks.
OPENAI_MODEL=gpt-4o-mini

# ---- Tavily (public-web grounding for tavily_agent) ----
# https://app.tavily.com/home
TAVILY_API_KEY=

# ---- Pioneer.ai (OpenAI-compatible chat completions for domain reasoning) ----
# Docs: https://docs.pioneer.ai/
# Adapter: src/lib/training/pioneer.ts → pioneerChat(messages, opts)
#
# Auth header: Authorization: Bearer pio_sk_xxx
# Endpoint: POST {PIONEER_BASE_URL}/v1/chat/completions
#
# PIONEER_MODEL_ID is a Pioneer UUID:
#   - hosted gpt-5.5 → use the gpt-5.5 model id from the Pioneer dashboard
#   - later, swap in a Pioneer-fine-tuned local model trained on wine corpus
PIONEER_API_KEY=
PIONEER_BASE_URL=https://api.pioneer.ai
PIONEER_MODEL_ID=

# ---- Server runtime ----
NEXT_PUBLIC_APP_URL=http://localhost:3000
