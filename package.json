    "better-sqlite3": "^11.7.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.38.3",
    "lucide-react": "^0.469.0",
    "next": "^15.1.6",
    "openai": "^4.78.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
